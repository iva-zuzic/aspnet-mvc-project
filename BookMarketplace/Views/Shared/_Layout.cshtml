<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookMarketplace</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookMarketplace.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="site-nav">
            <div class="nav-inner">
                <a class="nav-brand" asp-controller="Home" asp-action="Index">
                    <span class="nav-brand-icon" aria-hidden="true">&#9783;</span>
                    BookMarketplace
                </a>
                <ul class="nav-links">
                    <li><a asp-controller="Home" asp-action="Index">Po&#269;etna</a></li>
                    <li><a asp-controller="Grad" asp-action="Index">Gradovi</a></li>
                    <li><a asp-controller="Knjiga" asp-action="Index">Knjige</a></li>
                    <li><a asp-controller="DrustvenaIgra" asp-action="Index">Igre</a></li>
                    <li><a asp-controller="Poruka" asp-action="Index">Inbox</a></li>
                </ul>
                <ul class="nav-auth">
                    <li><a href="#">Prijava</a></li>
                    <li><a href="#">Registracija</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="site-main" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span>&copy; 2026 BookMarketplace</span>
            <a asp-controller="Home" asp-action="Privacy">Privatnost</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
