@model GradEditModel

@{
    ViewData["Title"] = "Uredi grad";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Uredi grad</h1>
        <a class="btn-secondary" asp-area="Admin" asp-controller="Grad" asp-action="Index">
            &larr; Natrag na popis
        </a>
    </div>

    <div class="form-card">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Naziv" class="form-label"></label>
                <input asp-for="Naziv" class="form-input" />
                <span asp-validation-for="Naziv" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PostanskiBroj" class="form-label"></label>
                <input asp-for="PostanskiBroj" class="form-input" />
                <span asp-validation-for="PostanskiBroj" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Spremi izmjene</button>
                <a class="btn-secondary" asp-area="Admin" asp-controller="Grad" asp-action="Index">
                    Odustani
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}