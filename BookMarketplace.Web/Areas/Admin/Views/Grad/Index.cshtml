@model List<Grad>

@{
    ViewData["Title"] = "Gradovi";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Gradovi</h1>
        <a class="btn-primary" asp-area="Admin" asp-controller="Grad" asp-action="Create">
            + Dodaj novi grad
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <p class="empty-state">Trenutno nema gradova u bazi.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Poštanski broj</th>
                    <th>Broj oglasa</th>
                    <th class="actions-col">Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grad in Model)
                {
                    <tr>
                        <td>
                            <a asp-area="Admin" asp-controller="Grad"
                               asp-action="Details" asp-route-id="@grad.Id"
                               class="oglas-naslov-link">
                                @grad.Naziv
                            </a>
                        </td>
                        <td>@grad.PostanskiBroj</td>
                        <td>@grad.Oglasi.Count</td>
                        <td class="actions-col">
                            <a class="btn-edit" 
                               asp-area="Admin" asp-controller="Grad" 
                               asp-action="Edit" asp-route-id="@grad.Id">
                                Uredi
                            </a>
                            <a class="btn-delete" 
                               asp-area="Admin" asp-controller="Grad" 
                               asp-action="Delete" asp-route-id="@grad.Id">
                                Obriši
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>