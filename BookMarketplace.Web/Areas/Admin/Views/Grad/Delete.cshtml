@model Grad

@{
    ViewData["Title"] = "Brisanje grada";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Brisanje grada</h1>
        <a class="btn-secondary" asp-area="Admin" asp-controller="Grad" asp-action="Index">
            &larr; Natrag na popis
        </a>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="delete-card">
        <p class="delete-warning">
            Jeste li sigurni da želite obrisati ovaj grad?
        </p>

        <dl class="entity-details">
            <dt>Naziv</dt>
            <dd>@Model.Naziv</dd>

            <dt>Poštanski broj</dt>
            <dd>@Model.PostanskiBroj</dd>

            <dt>Broj povezanih oglasa</dt>
            <dd>@Model.Oglasi.Count</dd>
        </dl>

        @if (Model.Oglasi.Any())
        {
            <div class="alert-warning">
                <strong>Pažnja:</strong> Ovaj grad ima @Model.Oglasi.Count povezan(ih) oglas(a) i ne može se obrisati.
            </div>
        }

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn-delete" @(Model.Oglasi.Any() ? "disabled" : "")>
                Da, obriši
            </button>
            <a class="btn-secondary" asp-area="Admin" asp-controller="Grad" asp-action="Index">
                Odustani
            </a>
        </form>
    </div>
</div>