@model IEnumerable<BookMarketplace.Model.Korisnik>

<section class="entity-page entity-page-user">
    <div class="page-heading entity-page-header">
        <div>
            <h1>Korisnici</h1>
            <p>Pregled svih registriranih korisnika s jasno odvojenim akcijama.</p>
        </div>
        <a asp-controller="Korisnik" asp-action="Create" class="button button-primary">Kreiraj novog korisnika</a>
    </div>

    <div class="entity-card table-card">
        <table class="entity-table">
            <thead>
                <tr>
                    <th>Ime i prezime</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in Model)
                {
                    <tr>
                        <td>@k.ImeIPrezime</td>
                        <td>@k.Email</td>
                        <td>@k.Telefon</td>
                        <td>
                            <div class="table-actions">
                                <a asp-controller="Korisnik" asp-action="Edit" asp-route-id="@k.Id" class="button button-secondary">Uredi</a>
                                <a asp-controller="Korisnik" asp-action="Delete" asp-route-id="@k.Id" class="button button-danger button-danger-soft">Obriši</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>