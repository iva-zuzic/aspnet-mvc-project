@model List<Korisnik>
@{
    ViewData["Title"] = "Korisnici";
}

<div class="page-heading">
    <h1>Korisnici</h1>
    <p>@Model.Count korisnika</p>
</div>

<div style="margin-bottom: 1.5rem;">
    <a class="btn-primary" asp-controller="Korisnik" asp-action="Create">+ Novi korisnik</a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <p>Nema registriranih korisnika.</p>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var korisnik in Model)
        {
            <a class="card card-grad" asp-controller="Korisnik" asp-action="Details" asp-route-id="@korisnik.Id">
                <div class="card-body">
                    <span class="card-title">@korisnik.ImeIPrezime</span>
                    <span class="card-subtitle">@korisnik.Email</span>
                    <span class="card-count">@korisnik.Oglasi.Count @(korisnik.Oglasi.Count == 1 ? "oglas" : "oglasa")</span>
                </div>
            </a>
        }
    </div>
}