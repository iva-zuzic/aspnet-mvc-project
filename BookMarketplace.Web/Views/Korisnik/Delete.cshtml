@model BookMarketplace.Model.Korisnik

<section class="entity-page entity-page-user">
    <div class="page-heading">
        <h1>Obriši korisnika</h1>
        <p>Prije brisanja provjerite da je odabran ispravan korisnički zapis.</p>
    </div>

    <div class="entity-card entity-delete-card">
        <div class="entity-delete-copy">
            <h2>@Model.ImeIPrezime</h2>
            <p>Ova radnja trajno uklanja korisnika iz sustava.</p>
        </div>

        <dl class="entity-summary-grid">
            <div>
                <dt>Email</dt>
                <dd>@Model.Email</dd>
            </div>
            <div>
                <dt>Telefon</dt>
                <dd>@Model.Telefon</dd>
            </div>
        </dl>

        <form asp-action="Delete" class="form-actions">
            <input type="hidden" asp-for="Id" />
            <a asp-controller="Korisnik" asp-action="Index" class="button button-secondary">Odustani</a>
            <button type="submit" class="button button-danger">Obriši korisnika</button>
        </form>
    </div>
</section>