@model BookMarketplace.Web.ViewModels.KorisnikCreateModel

@{
    ViewData["Title"] = "Novi korisnik";
}

<div class="form-container">
    <div class="form-header">
        <h1>Registracija</h1>
        <p class="form-subtitle">Kreirajte novi korisnički račun.</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="ImeIPrezime" class="form-label"></label>
                <input asp-for="ImeIPrezime" class="form-input" placeholder="npr. Ana Horvat" />
                <span asp-validation-for="ImeIPrezime" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-input" type="email" placeholder="ana@example.com" />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Lozinka" class="form-label"></label>
                <input asp-for="Lozinka" class="form-input" type="password" />
                <span asp-validation-for="Lozinka" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefon" class="form-label"></label>
                <input asp-for="Telefon" class="form-input" placeholder="+385 91 234 5678" />
                <span asp-validation-for="Telefon" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary btn-large">Registriraj se</button>
                <a class="btn-secondary" asp-controller="Korisnik" asp-action="Index">Odustani</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}