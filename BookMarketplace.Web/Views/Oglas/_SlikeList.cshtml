@model IEnumerable<BookMarketplace.Model.Slika>

@if (!Model.Any())
{
    <p class="text-muted">Nema dodanih slika.</p>
}
else
{
    var slike = Model.OrderBy(s => s.RedoslijedPrikaza).ToList();

    <div class="uploaded-images-grid">
        @for (int i = 0; i < slike.Count; i++)
        {
            var slika = slike[i];

            <div class="uploaded-image-card">
                <div class="uploaded-image-preview">
                    <img src="@slika.Putanja" alt="Slika @(i + 1)" />
                </div>

                <div class="uploaded-image-info">
                    <p class="uploaded-image-title">Slika @(i + 1)</p>
                </div>

                <button type="button"
                        class="btn-delete-image"
                        onclick="deleteSlika(@slika.Id)">
                    Obriši
                </button>
            </div>
        }
    </div>
}