@using System.Globalization
@model Oglas
@using System.Security.Claims
@{
    ViewData["Title"] = Model.DrustvenaIgra?.Naziv ?? Model.Naslov;

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    var canManageAd = User.IsInRole("Admin")
        || (User.Identity?.IsAuthenticated == true
            && Model.Korisnik?.AppUserId == currentUserId);
}

<nav class="breadcrumb">
    <a asp-controller="DrustvenaIgra" asp-action="Index">Igre</a>
    <span class="breadcrumb-sep">&rsaquo;</span>
    <span>@Model.DrustvenaIgra?.Zanr</span>
    <span class="breadcrumb-sep">&rsaquo;</span>
    <span class="breadcrumb-current">@Model.DrustvenaIgra?.Naziv</span>
</nav>

<div class="detail-card detail-card-full">
    <div class="detail-layout">
        <partial name="_OglasDetailsImages" model="Model" />
        <div class="detail-info">
            <div class="detail-grid">
                <span class="detail-label">Naziv</span>
                <span class="detail-value">@Model.DrustvenaIgra?.Naziv</span>

                <span class="detail-label">Broj igra&#269;a</span>
                <span class="detail-value">@Model.DrustvenaIgra?.BrojIgracaPrikaz</span>

                <span class="detail-label">Minimalna dob</span>
                <span class="detail-value">@Model.DrustvenaIgra?.MinimalnaDob+</span>

                <span class="detail-label">Trajanje</span>
                <span class="detail-value">@Model.DrustvenaIgra?.TrajanjeMins min</span>

                <span class="detail-label">&#381;anr</span>
                <span class="detail-value">@Model.DrustvenaIgra?.Zanr</span>

                <span class="detail-label">Cijena</span>
                <span class="detail-value card-price">@Model.Cijena.ToString("N2") &euro;</span>

                <span class="detail-label">Stanje artikla</span>
                <span class="detail-value">@Model.StanjeArtikla</span>

                <span class="detail-label">Opis</span>
                <span class="detail-value">@Model.Opis</span>

                <span class="detail-label">Grad</span>
                <span class="detail-value">@Model.Grad?.Naziv</span>

                <span class="detail-label">Prodava&#269;</span>
                <span class="detail-value">@Model.Korisnik?.ImeIPrezime</span>

                <span class="detail-label">Datum objave</span>
                <span class="detail-value">
                    <span class="localized-datetime"
                        data-iso="@Model.DatumObjave.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture)">
                        @Model.DatumObjave.ToString("dd.MM.yyyy. HH:mm")
                    </span>
                </span>

                <span class="detail-label">Oglas istječe</span>
                <span class="detail-value">
                    <span class="localized-datetime"
                        data-iso="@(Model.DatumIsteka.HasValue ? Model.DatumIsteka.Value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture) : "")">
                        @(Model.DatumIsteka.HasValue
                            ? Model.DatumIsteka.Value.ToString("dd.MM.yyyy. HH:mm")
                            : "Nije navedeno")
                    </span>
                </span>
            </div>

            @if (canManageAd)
            {
                <div class="detail-actions">
                    <a class="btn-primary" asp-controller="Oglas" asp-action="Edit" asp-route-id="@Model.Id">
                        Uredi
                    </a>

                    <a class="btn-danger" asp-controller="Oglas" asp-action="Delete" asp-route-id="@Model.Id">
                        Obriši
                    </a>
                </div>
            }
        </div>
    </div>
</div>
