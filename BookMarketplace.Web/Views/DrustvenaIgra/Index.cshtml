@model List<Oglas>

@{
    ViewData["Title"] = "Društvene igre";
}

<div class="page-heading">
    <h1>Društvene igre</h1>
    <p id="igreCount">@Model.Count @(Model.Count == 1 ? "oglas za društvenu igru" : "oglasa za društvene igre")</p>
</div>

<div class="form-group search-box">
    <label for="igreSearch" class="form-label">Pretraži društvene igre</label>
    <input type="text"
           id="igreSearch"
           class="form-input"
           placeholder="Upišite naziv društvene igre..."
           autocomplete="off" />

    <p id="igreSearchStatus" class="search-status"></p>
</div>

<div id="igreResults">
    <partial name="_IgraCards" model="Model" />
</div>

@section Scripts {
    <script>
        $(function () {
            const $search = $('#igreSearch');
            const $results = $('#igreResults');
            const $count = $('#igreCount');
            const $status = $('#igreSearchStatus');

            let timer = null;
            let activeRequest = null;

            function formatBrojIgara(count) {
                return count === 1 ? '1 oglas za društvenu igru' : count + ' oglasa za društvene igre';
            }

            function pretraziIgre() {
                const term = $search.val().trim();

                if (activeRequest) {
                    activeRequest.abort();
                }

                $status.text('Pretraživanje...');

                activeRequest = $.ajax({
                    url: '@Url.Action("Search", "DrustvenaIgra")',
                    type: 'GET',
                    data: { term: term },
                    success: function (html) {
                        $results.hide().html(html).fadeIn(200);

                        const count = Number($results.find('.ajax-result-count').data('count'));

                        $count.text(formatBrojIgara(count));

                        if (term.length > 0) {
                            $status.text('Prikazani rezultati za: "' + term + '"');
                        } else {
                            $status.text('');
                        }
                    },
                    error: function (xhr, status) {
                        if (status === 'abort') {
                            return;
                        }

                        $results.html(
                            '<div class="empty-state"><p>Dogodila se greška kod pretrage.</p></div>'
                        );

                        $status.text('');
                    }
                });
            }

            $search.on('input', function () {
                clearTimeout(timer);

                timer = setTimeout(function () {
                    pretraziIgre();
                }, 250);
            });
        });
    </script>
}