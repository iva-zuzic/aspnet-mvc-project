<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Books &amp; Games</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookMarketplace.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="site-nav">
            <div class="nav-inner">
                <a class="nav-brand" asp-controller="Home" asp-action="Index">
                    <span class="nav-brand-icon" aria-hidden="true">&#9783;</span>
                    Books &amp; Games
                </a>

                <ul class="nav-links">
                    <li><a asp-controller="Knjiga" asp-action="Index">Knjige</a></li>
                    <li><a asp-controller="DrustvenaIgra" asp-action="Index">Društvene igre</a></li>
                    <li><a asp-controller="Grad" asp-action="Index">Gradovi</a></li>
                    <li><a asp-controller="Account" asp-action="MyAccount">Moj račun</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li>
                            <a asp-controller="Poruka" asp-action="Index">Poruke</a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a href="/Admin">Admin</a>
                        </li>
                    }
                </ul>

                <div class="nav-search">
                    <input type="text"
                        id="globalSearchInput"
                        class="nav-search-input"
                        placeholder="Pretraži knjige i igre..."
                        autocomplete="off" />

                    <div id="globalSearchResults" class="nav-search-results"></div>
                </div>

                <a asp-controller="Oglas" asp-action="Create" class="nav-cta">
                    + Objavi oglas
                </a>

                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>

    <main class="site-main" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span>&copy; 2026 Books &amp; Games</span>
            <a asp-controller="Home" asp-action="Privacy">Privatnost</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/autocomplete.js" asp-append-version="true"></script>
    <script src="~/js/global-search.js" asp-append-version="true"></script>
    <script src="~/js/datetime-picker.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
